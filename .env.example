# =============================================================================
# Trading Agent - Environment template
# Copy to .env and fill in. NEVER commit .env to git.
# =============================================================================

# --- Mode ---
# Allowed: paper | shadow | live
# paper  = no real orders, simulated fills using live data
# shadow = live data, real orders rejected before send (logged only)
# live   = real money. Requires explicit ENABLE_LIVE=true confirmation.
MODE=paper
ENABLE_LIVE=false

# --- Kite Connect ---
KITE_API_KEY=
KITE_API_SECRET=
KITE_USER_ID=
KITE_PASSWORD=
# Either KITE_PIN (6-digit Zerodha login PIN) OR KITE_TOTP_SECRET (Base32) must be set.
# If both are set, PIN takes precedence.
KITE_TOTP_SECRET=
KITE_PIN=
# Redirect URL configured in your Kite app (kite.trade developer console)
KITE_REDIRECT_URL=http://127.0.0.1:8000/kite/callback

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=trader
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=trading_agent

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Risk Engine (hard limits, read at startup) ---
SLOT_CAPITAL_INR=50000
MAX_RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_TRADES_PER_DAY=5
MAX_CONSECUTIVE_LOSSES=3
MAX_CONCURRENT_POSITIONS=3

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Observability ---
LOG_LEVEL=INFO
SENTRY_DSN=

# --- Kill switch ---
# Set to true to halt all new orders system-wide
KILL_SWITCH=false
